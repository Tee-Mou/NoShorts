{
    "manifest_version": 2,
    "name": "NoShorts",
    "version": "1.1",

    "description": "Redirects to the home page when trying to access YouTube Shorts.",

    "icons": {
        "96": "./icons/icon-96.png",
        "48": "./icons/icon-48.png"
    },

    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["noshorts.js"]
        }
    ],

    "browser_specific_settings": {
        "gecko": {
            "id": "noshorts@tmo",
            "data_collection_permissions": {
                "required": ["none"]
    }
  }
}
}